    <!-- Onboarding: Welcome -->
    <string name="onboarding_welcome_title">Reconecte-se com quem você quer ser</string>
    <string name="onboarding_welcome_body">Sabemos que existe um conflito real entre o que acreditamos e o que às vezes fazemos.\n\nCom base em pesquisas científicas, este aplicativo usa abordagens validadas para reduzir o consumo problemático de pornografia e ajudá-lo a viver de acordo com seus valores mais profundos.</string>

